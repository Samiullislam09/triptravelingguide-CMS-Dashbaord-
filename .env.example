# ============================================
# TripTravelingGuide AI Content Dashboard
# Environment Variables
# ============================================
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git — it holds secrets.

# ---------- Database: Supabase Postgres ----------
# Copy both strings from Supabase → Connect (top bar) → ORMs → Prisma.
# DATABASE_URL = pooled connection (Supavisor, port 6543) used at runtime.
# DIRECT_URL   = direct connection (port 5432) used by `prisma db push` / migrate.
# Replace [YOUR-PASSWORD] with your DB password and keep ?pgbouncer=true on the pooled one.
DATABASE_URL="postgresql://postgres.etuqhwpyfdpkgykexhnb:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.etuqhwpyfdpkgykexhnb:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# For image re-hosting into Supabase Storage during WordPress migration:
NEXT_PUBLIC_SUPABASE_URL="https://etuqhwpyfdpkgykexhnb.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="paste-service-role-key"

# ---------- Dashboard login (single-user auth) ----------
# This is YOUR login to the dashboard itself. Pick your own values.
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="change-this-to-a-strong-password"

# Secret key used to sign login session tokens. Generate a random one:
# run: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# ---------- Gemini API (free tier) ----------
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# ---------- WordPress connection ----------
# Your site URL, no trailing slash
WORDPRESS_URL="https://triptravelingguide.com"
# WordPress username (the account you generated the Application Password under)
WORDPRESS_USERNAME="your-wp-username"
# Generate at: WP Admin -> Users -> Profile -> Application Passwords
# Paste it exactly as WordPress shows it (with spaces is fine)
WORDPRESS_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# ---------- Publishing guardrail ----------
# Max articles allowed to publish per week (PDF Section 5.4 recommends 3-5)
WEEKLY_PUBLISH_CAP="5"
