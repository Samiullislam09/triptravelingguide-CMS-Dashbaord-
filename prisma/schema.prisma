// TripTravelingGuide AI Content Dashboard — Database Schema
// Mirrors Section 17 of the AI Content Automation Blueprint PDF

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres (Supabase, project ref etuqhwpyfdpkgykexhnb).
  //
  // IMPORTANT for Vercel/serverless: the DIRECT connection host
  // (db.<ref>.supabase.co:5432) is IPv6-ONLY, and Vercel functions have no IPv6
  // egress — using it in production makes every query fail with a 500. On
  // serverless you MUST use the IPv4 connection pooler (Supavisor):
  //   DATABASE_URL = Transaction pooler, port 6543 (runtime):
  //     postgresql://postgres.<ref>:[PW]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
  //   DIRECT_URL   = Session pooler, port 5432 (migrations / prisma db push):
  //     postgresql://postgres.<ref>:[PW]@aws-0-<region>.pooler.supabase.com:5432/postgres
  // Copy both from Supabase → Project Settings → Database → "Connection pooling".
  // The direct db.<ref>.supabase.co URL is fine for LOCAL dev only.
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NOTE: status/comparisonType are stored as String (not native enums) to keep
// the app code simple and provider-agnostic. Allowed values are kept in sync
// with the app code:
//   status         -> discovered | titled | drafted | seo_tagged | linked |
//                     imaged | pending_review | approved | published
//   comparisonType -> destination | transport | stay

model Article {
  id                String        @id @default(cuid())
  title             String
  slug              String        @unique
  status            String        @default("discovered")
  primaryKeyword    String
  contentHtml       String        @default("")
  contentMarkdown   String        @default("")
  wordCount         Int           @default(0)
  metaTitle         String        @default("")
  metaDescription   String        @default("")
  featuredImagePrompt String      @default("")
  comparisonType    String
  tags              String        @default("") // comma-separated SEO tags
  reasoning         String        @default("") // AI's plain-language "why this topic"
  titleAlternatives String        @default("") // JSON array of alternate headlines
  source            String        @default("ai") // ai | manual | wordpress — how the post was created
  wordpressPostId   String?
  wordpressUrl      String?

  // Real taxonomy + media (populated by the WordPress migration / manual posts)
  coverImageUrl     String        @default("")
  coverImageAlt     String        @default("")
  categoryName      String        @default("")
  categorySlug      String        @default("")

  // Content-quality recovery: thin/AI-fabricated posts get flagged for rewrite
  // instead of being deleted. The dashboard surfaces these for human action.
  needsRewrite      Boolean       @default(false)
  qualityNote       String        @default("") // why it was flagged (word count, fabricated data, etc.)

  // Scoring snapshot at time of discovery (PDF Section 3.3)
  topicScore        Float         @default(0)
  searchVolumeLow   Int           @default(0)
  searchVolumeHigh  Int           @default(0)
  keywordDifficulty Int           @default(0)
  trendDirection    String        @default("flat") // rising | flat | declining
  intentLabel       String        @default("")

  // SEO / quality checks (PDF Section 6.1)
  readabilityScore  Int           @default(0)
  duplicateScore    Int           @default(0)
  internalLinkCount Int           @default(0)
  externalLinkCount Int           @default(0)

  createdAt         DateTime      @default(now())
  approvedAt        DateTime?
  publishedAt       DateTime?

  // Generated cover/thumbnail (template-based, stored in Supabase)
  thumbnailUrl      String        @default("")
  thumbnailStatus   String        @default("none") // none | generated | approved

  humanInputMarkers HumanInputMarker[]
  internalLinks     InternalLink[]      @relation("SourceArticle")
  linkedFromArticles InternalLink[]     @relation("TargetArticle")
  externalLinks     ExternalLink[]
  analyticsSnapshots AnalyticsSnapshot[]
  reviewLogs        ReviewLog[]
  webStories        WebStory[]
}

// Auto-generated AMP-style web story derived from an article (or standalone).
// `slides` is a JSON array of { imageUrl, heading, text, cta? }.
model WebStory {
  id            String    @id @default(cuid())
  articleId     String?
  article       Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)
  title         String
  slug          String    @unique
  coverImageUrl String    @default("")
  slides        String    @default("[]")
  status        String    @default("draft") // draft | published
  source        String    @default("ai")    // ai | manual
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?
}

// Google Search Console query-level metrics (daily rows synced by lib/gsc.ts).
model KeywordMetric {
  id          String   @id @default(cuid())
  query       String
  page        String   @default("")
  date        DateTime
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  country     String   @default("")
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([date])
}

// Google Search Console page-level metrics (daily rows synced by lib/gsc.ts).
model PageMetric {
  id          String   @id @default(cuid())
  page        String
  date        DateTime
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([page])
  @@index([date])
}

// Simple key-value store: GSC connection state, last-sync timestamps, cached
// site totals, feature flags. Avoids a migration for every new setting.
model AppConfig {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

model HumanInputMarker {
  id         String   @id @default(cuid())
  articleId  String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  markerType String   // photo | price | experience | other
  markerText String
  resolved   Boolean  @default(false)
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
}

model InternalLink {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation("SourceArticle", fields: [articleId], references: [id], onDelete: Cascade)
  targetArticleId String
  targetArticle   Article  @relation("TargetArticle", fields: [targetArticleId], references: [id], onDelete: Cascade)
  anchorText      String
}

model ExternalLink {
  id                String   @id @default(cuid())
  articleId         String
  article           Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  url               String
  anchorText        String
  domain            String
  statusCheckPassed Boolean  @default(false)
  lastCheckedAt     DateTime?
}

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  avgPosition     Float    @default(0)
  sessions        Int      @default(0)
  bounceRate      Float    @default(0)
  adsenseRevenue  Float    @default(0)
  adsenseRpm      Float    @default(0)
  source          String   // gsc | ga4 | adsense
}

model ReviewLog {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  action          String   // edit | reject | approve
  timeSpentSeconds Int     @default(0)
  notes           String   @default("")
  createdAt       DateTime @default(now())
}

model PublishSchedule {
  id             String   @id @default(cuid())
  articleId      String
  scheduledFor   DateTime
  weeklyCapBucket String
  published      Boolean  @default(false)
  createdAt      DateTime @default(now())
}

// ⚠️ Supabase-managed tables (also written by the public frontend + lib/inbox.ts
// via supabase-js). Modeled here ONLY so `prisma db push` doesn't try to drop
// them. Do NOT change their columns from Prisma — edit them in Supabase.
model comments {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_slug      String
  name           String
  body           String
  parent_id      String?    @db.Uuid
  likes          Int        @default(0)
  approved       Boolean    @default(true)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  is_admin_reply Boolean    @default(false)
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_comments comments[] @relation("commentsTocomments")

  @@index([post_slug, created_at], map: "comments_post_slug_created_idx")
}

model contact_messages {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String
  message    String
  status     String   @default("new")
  created_at DateTime @default(now()) @db.Timestamptz(6)
}
